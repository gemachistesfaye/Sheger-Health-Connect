{
  "name": "sheger-health-connect-backend",
  "version": "2.0.0",
  "description": "Backend API for ShegerHealth - Telemedicine Platform",
  "main": "server.ts",
  "engines": {
    "node": ">=20.x"
  },
  "scripts": {
    "start": "tsx server.ts",
    "dev": "nodemon --exec tsx server.ts",
    "build": "tsc",
    "postinstall": "npm rebuild sqlite3",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint . --ext .ts,.js",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "format": "prettier --write .",
    "seed": "node seed-reset.js",
    "seed:admin": "node seed-admin.js",
    "migrate": "sequelize-cli db:migrate",
    "migrate:undo": "sequelize-cli db:migrate:undo",
    "migrate:undo:all": "sequelize-cli db:migrate:undo:all"
  },
  "keywords": [
    "telemedicine",
    "healthcare",
    "api",
    "express",
    "sequelize"
  ],
  "author": "Gemachis Tesfaye",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@socket.io/redis-adapter": "^8.0.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.22.3",
    "node-cache": "^5.1.2",
    "nodemailer": "^8.0.7",
    "openai": "^6.37.0",
    "pg": "^8.13.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "sequelize": "^6.37.8",
    "socket.io": "^4.8.3",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/helmet": "^0.0.48",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.10.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.3.3",
    "sequelize-cli": "^6.6.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.1",
    "typescript": "^5.5.0",
    "vitest": "^4.1.10"
  }
}
