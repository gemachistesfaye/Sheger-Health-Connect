# ==============================
# Sheger Health Connect - Environment Configuration
# ==============================

# ------------------------------
# Server Configuration
# ------------------------------
NODE_ENV=production
PORT=5000
HOST=0.0.0.0

# ------------------------------
# Database Configuration
# ------------------------------
# PostgreSQL (Supabase) - Recommended for production
DB_HOST=db.aocwlzqqxgolggejodbh.supabase.co
DB_USER=postgres
DB_PASS=your_database_password_here
DB_NAME=postgres
DB_PORT=5432
DB_DIALECT=postgres

# Set to 'false' in production (SQLite is NOT allowed in production)
USE_SQLITE=false

# ------------------------------
# Authentication
# ------------------------------
# Generate a strong random string (64+ characters) for JWT_SECRET
JWT_SECRET=your_jwt_secret_here_min_64_chars_long
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# ------------------------------
# Frontend Configuration
# ------------------------------
# Your deployed frontend URL (no trailing slash)
FRONTEND_URL=https://sheger-health-connect.vercel.app

# ------------------------------
# AI Configuration (Optional)
# ------------------------------
# OpenAI API Key or Google Gemini API Key
OPENAI_API_KEY=your_api_key_here

# ------------------------------
# Email Configuration (for password reset and verification)
# ------------------------------
# Gmail App Password (not your regular password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_app_password

# ------------------------------
# Rate Limiting (Optional - defaults shown)
# ------------------------------
RATE_LIMIT_GENERAL=100
RATE_LIMIT_AUTH=10
RATE_LIMIT_LOGIN=5
RATE_LIMIT_PASSWORD_RESET=3
RATE_LIMIT_AI=20

# ------------------------------
# Logging (Optional)
# ------------------------------
LOG_LEVEL=info
