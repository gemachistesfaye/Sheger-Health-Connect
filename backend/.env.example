# Server Configuration
PORT=5000
NODE_ENV=development

# MySQL connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=sheger-health-connect

# Set to 'true' to use SQLite instead of MySQL (NEVER use true in production)
USE_SQLITE=true

# JWT Secrets (generate a random 64+ character string for production)
JWT_SECRET=your_jwt_secret_here_min_64_characters
JWT_EXPIRES_IN=24h

# Frontend URL for CORS and password reset links
FRONTEND_URL=http://localhost:5173

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Email Configuration (for password reset)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Logging
LOG_LEVEL=info
