# ==============================
# Sheger Health Connect - Environment Configuration
# ==============================

# Server
NODE_ENV=production
PORT=5000
HOST=0.0.0.0
REQUEST_TIMEOUT_MS=30000

# Database
# OPTION 1 (Recommended for Render.com): Use a single connection string.
# Get this from Supabase → Project Settings → Database → Connection Pooling → Transaction mode
# IMPORTANT: Use the POOLER URL (port 6543), NOT the direct connection (port 5432)
# The pooler URL is IPv4-compatible and works on Render's free tier.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# OPTION 2: Use individual vars (use this if you're not on Render or have a direct DB)
# DB_HOST=your_db_host_here
# DB_USER=your_db_user_here
# DB_PASS=your_database_password_here
# DB_NAME=your_db_name_here
# DB_PORT=5432
# DB_DIALECT=postgres
USE_SQLITE=false

# Authentication
JWT_SECRET=your_jwt_secret_here_min_64_chars_long
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Frontend
FRONTEND_URL=https://sheger-health-connect.vercel.app

# AI (Optional)
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=500

# Email
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_app_password

# Rate Limiting
RATE_LIMIT_GENERAL=100
RATE_LIMIT_AUTH=10
RATE_LIMIT_LOGIN=5
RATE_LIMIT_PASSWORD_RESET=3
RATE_LIMIT_AI=20

# Account Security
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME_MS=900000

# Socket.io
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000

# Logging
LOG_LEVEL=info

# Admin (used by seed scripts)
ADMIN_PASSWORD=Admin@2026
